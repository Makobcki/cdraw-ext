  {
    "name": "set_position",
    "description": "Переместить объект в координаты страницы в единицах документа (doc.Unit). X растет вправо, Y растет вверх от нижнего левого угла страницы CorelDRAW. По умолчанию позиция задается для верхнего левого угла объекта (anchor='top_left').",
    "parameters": {
      "type": "object",
      "properties": {
        "ref": {
          "type": "string",
          "description": "Идентификатор объекта"
        },
        "x": {
          "type": "number",
          "description": "Координата X в единицах документа"
        },
        "y": {
          "type": "number",
          "description": "Координата Y в единицах документа"
        },
        "anchor": {
          "type": "string",
          "enum": [
            "top_left",
            "center",
            "bottom_left",
            "top_right",
            "bottom_right"
          ],
          "description": "Опорная точка привязки объекта (по умолчанию top_left)"
        }
      },
      "required": [
        "ref",
        "x",
        "y"
      ]
    }
  },
  {
    "name": "set_size",
    "description": "Задать ширину и высоту объекта в единицах документа (doc.Unit). По умолчанию масштабирование идет относительно верхнего левого угла без сохранения пропорций.",
    "parameters": {
      "type": "object",
      "properties": {
        "ref": {
          "type": "string",
          "description": "Идентификатор объекта"
        },
        "width": {
          "type": "number",
          "description": "Новая ширина объекта в единицах документа"
        },
        "height": {
          "type": "number",
          "description": "Новая высота объекта в единицах документа"
        },
        "keep_aspect_ratio": {
          "type": "boolean",
          "description": "Сохранять пропорции объекта (по умолчанию false)"
        },
        "anchor": {
          "type": "string",
          "enum": [
            "top_left",
            "center",
            "bottom_left"
          ],
          "description": "Опорная точка при изменении размера (по умолчанию top_left)"
        }
      },
      "required": [
        "ref",
        "width",
        "height"
      ]
    }
  },
  {
    "name": "rotate",
    "description": "Повернуть объект на заданный угол в градусах. Положительный угол — поворот против часовой стрелки (стандарт CorelDRAW), отрицательный — по часовой. По умолчанию поворот выполняется относительно центра объекта.",
    "parameters": {
      "type": "object",
      "properties": {
        "ref": {
          "type": "string",
          "description": "Идентификатор объекта"
        },
        "angle": {
          "type": "number",
          "description": "Угол поворота в градусах"
        },
        "pivot": {
          "type": "string",
          "enum": [
            "center",
            "top_left",
            "bottom_left",
            "top_right",
            "bottom_right"
          ],
          "description": "Точка пивота вращения (по умолчанию center)"
        }
      },
      "required": [
        "ref",
        "angle"
      ]
    }
  },
